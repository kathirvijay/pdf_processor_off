# Same database as pdf_processor (same credentials, same DB_NAME).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pdf_processor
DB_USER=postgres
DB_PASSWORD=postgres

# Required for pdf_processor_o: UUID of a user in the users table (same DB).
# Create a user in the main pdf_processor app (Register) or insert into users, then set this to that user's id.
STATIC_USER_ID=

# Or use a single URL (overrides DB_* above):
# DATABASE_URL=postgresql://user:password@localhost:5432/pdf_processor

# Ports (optional)
GATEWAY_PORT=5000
TEMPLATE_SERVICE_PORT=5002
PDF_SERVICE_PORT=5003
CSV_SERVICE_PORT=5004

# CORS (optional)
# CORS_ORIGIN=http://localhost:5173
